generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tenant {
  id         Int      @id @default(autoincrement())
  slug       String   @unique // The unique URL for the restaurant (e.g., /acai-do-joao)
  name       String
  planType           String   @default("basico") // basico, profissional, premium
  active             Boolean  @default(true)
  subscriptionStatus String   @default("trial") // trial, active, past_due, canceled
  nextBillingDate    DateTime?
  trialEndsAt        DateTime @default(dbgenerated("(datetime('now', '+7 days'))"))
  logoUrl            String?
  address            String?
  googleMapsUrl      String?
  openingHours       String? // JSON string: { "seg": { "open": "08:00", "close": "22:00" }, ... }
  paymentMethods     String? // Comma separated: pix,dinheiro,cartao
  primaryColor       String   @default("#3b82f6")
  description        String?
  readyMessage       String?
  minOrderDineIn     Float    @default(0)
  minOrderPickup     Float    @default(0)
  minOrderDelivery   Float    @default(0)
  deliveryFee            Float    @default(0)
  estimatedTime          String?  // Legado
  estimatedTimeDelivery  String?  // Ex: "40-50min / 1:30h"
  estimatedTimePickup    String?  // Ex: "30-40 min / 1:00h"
  extraInfo              String?  // Informação extra/avisos/promoções
  whatsapp               String?
  instagramUrl       String?
  facebookUrl        String?
  contactEmail       String?
  pdvPassword        String?  // Senha para o Frente de Caixa (PDV)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users      User[]
  categories Category[]
  products   Product[]
  orders     Order[]

  @@map("tenants")
}

model User {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  email     String   @unique
  password  String
  role      String   @default("admin") // admin, attendant
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("users")
}

model Category {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  name      String
  order     Int      @default(0) // Visual ordering for the menu
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]

  @@index([tenantId])
  @@map("categories")
}

model Product {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  categoryId  Int
  name        String
  description String?
  price       Float
  imageUrl    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]

  @@index([tenantId])
  @@index([categoryId])
  @@map("products")
}

model Order {
  id             Int      @id @default(autoincrement())
  orderNumber    Int?     // Sequential number for the establishment
  tenantId       Int
  customerName   String
  customerPhone  String
  totalAmount    Float
  status         String   @default("pending") // pending, accepted, preparing, ready, finished
  
  // v3 Fields
  fulfillmentType String   @default("delivery") // delivery, pickup, dine_in
  paymentMethod   String   @default("money")    // pix, card, money
  addressStreet   String?
  addressNumber   String?
  addressDistrict String?
  addressComplement String?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items          OrderItem[]

  @@index([tenantId])
  @@map("orders")
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  unitPrice Float

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Config {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String

  @@map("configs")
}
