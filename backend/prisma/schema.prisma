generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tenant {
  id         Int      @id @default(autoincrement())
  slug       String   @unique // The unique URL for the restaurant (e.g., /acai-do-joao)
  name       String
  ownerName  String?  // Nome do Responsável do Restaurante
  planType           String   @default("basico") // basico, profissional, premium
  active             Boolean  @default(true)
  subscriptionStatus String   @default("trial") // trial, active, past_due, canceled
  nextBillingDate    DateTime?
  trialEndsAt        DateTime @default(dbgenerated("(datetime('now', '+7 days'))"))
  logoUrl            String?
  address            String?
  googleMapsUrl      String?
  openingHours       String? // JSON string: { "seg": { "open": "08:00", "close": "22:00" }, ... }
  paymentMethods     String? // Comma separated: pix,dinheiro,cartao
  primaryColor       String   @default("#3b82f6")
  description        String?
  readyMessage       String?
  minOrderDineIn     Float    @default(0)
  minOrderPickup     Float    @default(0)
  minOrderDelivery   Float    @default(0)
  deliveryFee            Float    @default(0)
  estimatedTime          String?  // Legado
  estimatedTimeDelivery  String?  // Ex: "40-50min / 1:30h"
  estimatedTimePickup    String?  // Ex: "30-40 min / 1:00h"
  extraInfo              String?  // Informação extra/avisos/promoções
  whatsapp               String?
  instagramUrl       String?
  facebookUrl        String?
  contactEmail       String?
  pdvPassword        String?  // Senha para o Frente de Caixa (PDV)
  
  // Logistics v2 (Geoapify)
  acceptDelivery     Boolean  @default(true)
  valorKm            Float    @default(0)
  raioMaxKm          Float    @default(0)
  lat                Float?
  lon                Float?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users       User[]
  categories  Category[]
  products    Product[]
  orders      Order[]
  tables      Table[]
  drivers     Driver[]
  addonGroups AddonGroup[]
  coupons     Coupon[]
  customers   Customer[]
  cashRegisterEvents CashRegisterEvent[]

  @@map("tenants")
}

model Table {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  number    Int
  active    Boolean  @default(true)
  qrCodeUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders    Order[]

  @@index([tenantId])
  @@map("tables")
}

model Driver {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  name      String
  phone     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders    Order[]

  @@index([tenantId])
  @@map("drivers")
}

model User {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  email     String   @unique
  password  String
  role      String   @default("admin") // admin, attendant
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("users")
}

model Category {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  name      String
  order     Int      @default(0) // Visual ordering for the menu
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]

  @@index([tenantId])
  @@map("categories")
}

model Product {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  categoryId  Int
  name        String
  description String?
  price       Float
  imageUrl    String?
  active      Boolean  @default(true)
  order       Int      @default(0) // Visual ordering
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Professional Fields
  useStock      Boolean @default(false)
  stockQuantity Int     @default(0)
  
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems  OrderItem[]
  addonGroups AddonGroup[] @relation("ProductAddonGroups")

  @@index([tenantId])
  @@index([categoryId])
  @@map("products")
}

model AddonGroup {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  name        String   // Ex: Seus Molhos, Tamanho, Meio a Meio
  minChoices  Int      @default(0)
  maxChoices  Int      @default(1)
  isRequired  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  addons      Addon[]
  products    Product[] @relation("ProductAddonGroups")

  @@index([tenantId])
  @@map("addon_groups")
}

model Addon {
  id           Int      @id @default(autoincrement())
  addonGroupId Int
  name         String
  price        Float    @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  group        AddonGroup @relation(fields: [addonGroupId], references: [id], onDelete: Cascade)
  orderItemAddons OrderItemAddon[]

  @@index([addonGroupId])
  @@map("addons")
}

model Customer {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  phone     String   // Unique identifier for customer in a tenant
  name      String?
  address   String?
  email     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders    Order[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@map("customers")
}

model Coupon {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  code        String
  type        String   // fixed, percentage
  value       Float
  minOrder    Float    @default(0)
  maxUsage    Int?
  usedCount   Int      @default(0)
  expiresAt   DateTime?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders      Order[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("coupons")
}

model Order {
  id             Int      @id @default(autoincrement())
  orderNumber    Int?     // Sequential number for the establishment
  tenantId       Int
  tableId        Int?     // Vínculo opcional com Mesa
  driverId       Int?     // Vínculo opcional com Entregador
  customerId     Int?     // Vínculo com Cliente persistente
  couponId       Int?     // Cupom aplicado

  customerName   String
  customerPhone  String
  totalAmount    Float
  discountAmount Float    @default(0)
  deliveryFeeAmount Float @default(0)
  status         String   @default("pending") // pending, accepted, preparing, ready, finished, cancelled
  cancelReason   String?  // Motivo do cancelamento
  cancellationRequested Boolean @default(false) // Se o cliente pediu cancelamento
  
  // v3 Fields
  fulfillmentType String   @default("delivery") // delivery, pickup, dine_in, counter
  paymentMethod   String   @default("money")    // pix, card, money
  addressStreet   String?
  addressNumber   String?
  addressDistrict String?
  addressCity     String?
  addressState    String?
  addressComplement String?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  table          Table?   @relation(fields: [tableId], references: [id])
  driver         Driver?  @relation(fields: [driverId], references: [id])
  customer       Customer? @relation(fields: [customerId], references: [id])
  coupon         Coupon?   @relation(fields: [couponId], references: [id])
  items          OrderItem[]

  @@index([tenantId])
  @@index([tableId])
  @@index([driverId])
  @@index([customerId])
  @@index([couponId])
  @@map("orders")
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  unitPrice Float
  notes     String?

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  addons    OrderItemAddon[]

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model OrderItemAddon {
  id          Int      @id @default(autoincrement())
  orderItemId Int
  addonId     Int
  name        String   // Snapshot for history
  price       Float    // Snapshot for history

  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  addon       Addon     @relation(fields: [addonId], references: [id])

  @@index([orderItemId])
  @@index([addonId])
  @@map("order_item_addons")
}

model CashRegisterEvent {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  type        String   // open, close, inflow (reforço), outflow (sangria)
  amount      Float    @default(0)
  description String?
  userId      Int?      // Quem realizou a operação
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("cash_register_events")
}

model Config {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String

  @@map("configs")
}

